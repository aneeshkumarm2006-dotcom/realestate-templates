# ============================================================
# CMS configuration. Copy to .env.local for local dev.
# On Vercel, set these in Project → Settings → Environment Variables.
#
# This file is a TEMPLATE and is committed to the repo.
# NEVER put real values here — only in .env.local (gitignored)
# or in Vercel's environment settings.
# ============================================================

# --- Admin login (required everywhere the CMS runs) ---
ADMIN_EMAIL=you@example.com
ADMIN_PASSWORD=change-me
# Any long random string, e.g. `openssl rand -hex 32`
AUTH_SECRET=change-me

# --- GitHub persistence (Vercel/production only) ---
# When CMS_STORAGE=github, every CMS save becomes a Git commit on the
# repo below, and Vercel redeploys the site automatically (~1–2 min).
# Leave these UNSET for local dev — local saves write files directly,
# which you review and commit yourself.
#
# GITHUB_TOKEN: fine-grained personal access token with
#   Repository access = this repo only, Permissions = Contents: Read & write.
# GITHUB_REPO: the CLIENT's repo created from this template — owner/name.
# CMS_STORAGE=github
# GITHUB_TOKEN=github_pat_xxx
# GITHUB_REPO=your-org/client-site
# GITHUB_BRANCH=main

# --- Showcase mode (OUR demo deployment ONLY — never a client site) ---
# Renders a floating switcher that lets a visitor preview every template and
# palette on one live URL. The choice is stored in a cookie and resolved on the
# server, so what you see is exactly what that configuration deploys as.
#
# Leave this UNSET on client sites. With it unset:
#   - the switcher is never rendered,
#   - no cookie is read, so the public pages stay statically prerendered,
#   - the template + palette are fixed by content/brand.json and a visitor
#     cannot reskin the client's site.
# Setting it opts the public routes into dynamic (per-request) rendering.
# SHOWCASE=1

# --- Optional ---
# Email attributed to CMS-authored commits. Cosmetic; never contacted.
# CMS_COMMIT_EMAIL=cms@example.com
